                "ClusterId": "identity-cluster",
                "AuthorizationPolicy": "Anonymous",
                "Match": {
                    "Path": "/identity/swagger/{**catch-all}"
                },
                "Transforms": [
                    { "PathRemovePrefix": "/identity" }
                ]
            },
